# Supabase 설정
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Auth 로컬 검증
AUTH_LOCAL_VERIFY=True

# Gemini API 설정
GEMINI_API_KEY=your-gemini-api-key

# LLM 모델 설정
LLM_VISION_MODEL=gemini-3.1-flash
LLM_VISION_TEMPERATURE=0.2
LLM_VISION_THINKING_LEVEL=default
LLM_TEXT_MODEL=gemini-2.5-flash
LLM_TEXT_TEMPERATURE=0.2
LLM_TEXT_THINKING_LEVEL=default

# OCR LLM 설정
LLM_OCR_MODEL=gemini-3.1-flash-lite-preview
LLM_OCR_TEMPERATURE=1.0
LLM_OCR_THINKING_LEVEL=medium

# Dify API 설정 (기본 생성용)
DIFY_API_KEY=your-dify-api-key
# 옵션 A (Cloudflare 경유, 설정 변경 없음): https://dify.vodqar.com/v1
# 옵션 B (컨테이너→호스트 직접, 지연 최소화): http://host.docker.internal:8080/v1
DIFY_API_URL=https://dify.vodqar.com/v1

# Dify API 설정 (재생성/수정용 — 미설정 시 기본값 사용)
DIFY_REGENERATE_API_KEY=your-dify-regenerate-api-key
DIFY_REGENERATE_API_URL=https://dify.vodqar.com/v1

# 기상청 단기예보 API 키
KMA_API_KEY=your-kma-auth-key

# 기상청 중기예보 API 키
KMA_MID_API_KEY=your-kma-mid-service-key

# 한국천문연구원 특일 정보 API 키
KMA_SPECIAL_DAY_API_KEY=your-kasi-special-day-service-key

# Dify 인삿말 생성용 Chatflow
DIFY_GREETING_API_KEY=your-dify-greeting-api-key
DIFY_GREETING_API_URL=https://dify.vodqar.com/v1

# 애플리케이션 설정
APP_NAME=Nuri-GPT
APP_VERSION=0.1.0
DEBUG=False

# 서버 설정
HOST=0.0.0.0
PORT=8000

# CORS 설정 (프로덕션 도메인만)
CORS_ORIGINS=https://nuri-gpt.vodqar.com
